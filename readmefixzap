### 2. `server.js` — Ajout du header Permissions-Policy

**Problème :** helmet ne génère pas automatiquement le header `Permissions-Policy` avec les valeurs restrictives attendues par ZAP.

**Solution :** Middleware dédié après helmet :

```javascript
app.use((req, res, next) => {
  res.setHeader('Permissions-Policy', 'geolocation=(), microphone=(), camera=()');
  next();
});
```

---

### 3. `server.js` — Protection CSRF sur tous les formulaires POST

**Problème :** Aucun token CSRF sur les formulaires → ZAP détecte l'absence de protection [10202].

**Solution :** Génération d'un token CSRF dans la session et vérification sur chaque route POST.

```javascript
// Génération du token
const crypto = require('crypto');
app.use((req, res, next) => {
  if (!req.session.csrfToken) {
    req.session.csrfToken = crypto.randomBytes(32).toString('hex');
  }
  res.locals.csrfToken = req.session.csrfToken;
  next();
});

// Vérification du token
function verifyCsrf(req, res, next) {
  const token = req.body._csrf || req.headers['x-csrf-token'];
  if (!token || token !== req.session.csrfToken) {
    return res.status(403).send('Invalid CSRF token');
  }
  next();
}

// Application sur les routes POST
app.post('/login',       verifyCsrf, ...);
app.post('/ping',        requireAuth, verifyCsrf, ...);
app.post('/deserialize', requireAuth, verifyCsrf, ...);
app.post('/xml',         requireAuth, verifyCsrf, ...);
```

